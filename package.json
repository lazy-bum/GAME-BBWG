{
  "name": "bb-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "奔奔批量兑换网页版",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:wechat": "node dist/server.js --wechat",
    "start:wechat:login": "node dist/server.js --wechat --force-wechat-login",
    "wechat:login": "tsx src/scripts/forceWechatLogin.ts"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jpeg-js": "^0.4.4",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "qrcode-terminal": "^0.12.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jpeg-js": "^0.3.0",
    "@types/node": "^24.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
